    {
      "name": "Chronic Spontaneous Urticaria",
      "pa_required": true,
      "icd10_codes": [
        "<UNKNOWN>"
      ],
      "initial_authorization": {
        "criteria": [
          {
            "criterion_type": "diagnosis",
            "description": "Diagnosis of chronic spontaneous urticaria",
            "logic_operator": "AND"
          },
          {
            "criterion_type": "step_therapy",
            "description": "Patient remains symptomatic despite at least a 2-week trial of, or history of contraindication or intolerance to, two H1-antihistamines [e.g., Allegra (fexofenadine), Benadryl (diphenhydramine), Claritin (loratadine)]",
            "logic_operator": "OR"
          },
          {
            "criterion_type": "step_therapy",
            "description": "Patient remains symptomatic despite at least a 2-week trial of, or history of contraindication or intolerance to both of the following taken in combination: a second generation H1-antihistamine [e.g., Allegra (fexofenadine), Claritin (loratadine), Zyrtec (cetirizine)] AND one of the following: a different second generation H1-antihistamine, a first generation H1-antihistamine, an H2-antihistamine, or a leukotriene modifier",
            "logic_operator": "AND"
          },
          {
            "criterion_type": "combination_restriction",
            "description": "Patient is not receiving Dupixent in combination with Xolair (omalizumab) for treatment of the same indication",
            "logic_operator": "AND"
          },
          {
            "criterion_type": "prescriber",
            "description": "Prescribed by one of the following: Allergist, Dermatologist, Immunologist",
            "logic_operator": "AND"
          }
        ],
        "authorization_duration_months": 12,
